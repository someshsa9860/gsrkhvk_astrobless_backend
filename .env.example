# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
APP_NAME=myapp
APP_VERSION=1.0.0
REGION=ap-south-1
APP_BASE_URL=https://myapp.com
ADMIN_BASE_URL=https://admin.myapp.com

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/astrobless

# Redis
REDIS_URL=redis://localhost:6379

# JWT — audience-scoped (min 32 chars each)
JWT_SECRET_CUSTOMER=change_me_customer_secret_at_least_32chars
JWT_REFRESH_SECRET_CUSTOMER=change_me_customer_refresh_secret_32chars
JWT_SECRET_ASTROLOGER=change_me_astrologer_secret_at_least32ch
JWT_REFRESH_SECRET_ASTROLOGER=change_me_astrologer_refresh_secret_32ch
JWT_SECRET_ADMIN=change_me_admin_secret_at_least_32_chars_x
JWT_REFRESH_SECRET_ADMIN=change_me_admin_refresh_secret_32chars_x

# Google OAuth (customer only)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Apple Sign-In (customer iOS only)
APPLE_SERVICE_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# SMS OTP (MSG91)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=ASTBLS
MSG91_OTP_TEMPLATE_ID=

# Email (MSG91 transactional / SES fallback)
SES_REGION=ap-south-1
SES_FROM_EMAIL=noreply@astrobless.app
MSG91_EMAIL_DOMAIN=
MSG91_EMAIL_OTP_TEMPLATE_ID=

# Currency (default INR — change to USD etc. for international markets)
DEFAULT_CURRENCY=INR

# Test mode — set to true in local dev to accept OTP "123456" without real SMS/email
TEST_OTP=false

# Seed admin email (used by npm run db:seed)
SEED_ADMIN_EMAIL=tech@callvcal.com

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Google Play Billing (Android IAP)
GOOGLE_PLAY_PACKAGE_NAME=com.astrobless.app
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=         # path to service account JSON or inline JSON

# Apple In-App Purchase (iOS)
APPLE_IAP_SHARED_SECRET=                  # App-specific shared secret from App Store Connect → My Apps → {App} → App Information
APPLE_IAP_VERIFY_URL=https://buy.itunes.apple.com/verifyReceipt  # use https://sandbox.itunes.apple.com/verifyReceipt for dev

# PhonePe
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=1
PHONEPE_BASE_URL=https://api-preprod.phonepe.com/apis/pg-sandbox

# Google Pay
GOOGLE_PAY_MERCHANT_ID=

# Apple Pay
APPLE_PAY_MERCHANT_ID=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Agora (single provider for all calls)
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# Firebase FCM
FCM_SERVICE_ACCOUNT_JSON=

# AWS S3
S3_BUCKET=astrobless-dev
S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# CloudFront CDN (optional — leave blank to use direct S3 URLs)
# Get CLOUDFRONT_DOMAIN from your CF distribution (e.g. d1234abcd.cloudfront.net)
# Get CLOUDFRONT_KEY_PAIR_ID from AWS Console → CloudFront → Key management → Public keys
# CLOUDFRONT_PRIVATE_KEY: path to .pem file OR raw PEM string
CLOUDFRONT_DOMAIN=
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY=/run/secrets/cloudfront.pem
CLOUDFRONT_URL_TTL_SECONDS=3600

# Anthropic Claude
ANTHROPIC_API_KEY=

# Observability
SENTRY_DSN=
LOKI_URL=http://localhost:3100
TEMPO_URL=http://localhost:4317
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Feature flags
ENABLE_AI_CHAT=true
ENABLE_VIDEO_CALLS=false

# Admin panel WebSocket URL (used by admin panel SSE proxy — defaults to same as API)
BACKEND_WS_URL=ws://localhost:3000
